FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /bin/chatvault-api ./cmd/chatvault-api

FROM gcr.io/distroless/static-debian12
COPY --from=builder /bin/chatvault-api /chatvault-api
WORKDIR /
ENTRYPOINT ["/chatvault-api"]
